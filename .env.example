# ==============================================================================
# Campeonato MundIAl 4Match — Variables de entorno (ver AGENTS.md §19.2)
# Copiar este archivo como .env dentro de cada app (apps/server/.env y
# apps/web/.env.local). Los valores de abajo son defaults útiles para dev.
# ==============================================================================

# ------------------------------------------------------------------------------
# apps/server/.env
# ------------------------------------------------------------------------------
NODE_ENV=development
PORT=4000

# Redis (AOF activado en prod — ver §10.5)
REDIS_URL=redis://localhost:6379

# Sesiones (§17)
JWT_SECRET=dev-secret-cambiar-en-prod-minimo-32-chars
ADMIN_TOKEN=dev-admin-token

# Parámetros de partida (§4.1)
MATCH_DURATION_SECONDS=120
CARDS_PER_PLAYER=15
TURN_PICK_TIMEOUT_SECONDS=10
RECONNECT_GRACE_SECONDS=30
MATCH_STALL_TIMEOUT_SECONDS=15

# CORS para el websocket
CORS_ORIGIN=http://localhost:3000

# Bootstrap del torneo default (se crea al arrancar si no existe)
BOOTSTRAP_TOURNAMENT_ID=t-default
BOOTSTRAP_TOURNAMENT_NAME=Campeonato MundIAl 4Match
BOOTSTRAP_CUPO_MAX=256

# Logging (nestjs-pino)
LOG_LEVEL=info

# ------------------------------------------------------------------------------
# apps/web/.env.local
# ------------------------------------------------------------------------------
NEXT_PUBLIC_SOCKET_URL=http://localhost:4000
# Opcional: torneo fijo inyectado en build-time (si se omite se toma del path)
# NEXT_PUBLIC_TOURNAMENT_ID=
# Fallback usado por Docker/Railway si no se define NEXT_PUBLIC_TOURNAMENT_ID
NEXT_PUBLIC_DEFAULT_TID=t-default
